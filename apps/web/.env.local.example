# Supabase Configuration
# Get these values from https://supabase.com/dashboard

# Your Supabase project URL
# Found in: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase public (anon) API key
# Found in: Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your app's redirect URL (used for OAuth callbacks)
# For local development, this should be your localhost URL
NEXT_PUBLIC_REDIRECT_URL=http://localhost:3000

# Optional: API Configuration (if using Express backend)
NEXT_PUBLIC_API_URL=http://localhost:5001
